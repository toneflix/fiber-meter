{
    "name": "fibermeter",
    "private": true,
    "version": "0.1.0",
    "description": "FiberMeter monorepo",
    "scripts": {
        "bootstrap": "node scripts/bootstrap.mjs",
        "autopay": "node scripts/autopay.mjs",
        "build": "pnpm -r build",
        "test": "pnpm -r test",
        "dev": "pnpm --parallel dev",
        "run:node:payer": "FIBER_SECRET_KEY_PASSWORD='password' RUST_LOG=info ./fiber-payer/fnn -c ./fiber-payer/config.yml -d ./fiber-payer",
        "run:node:payee": "FIBER_SECRET_KEY_PASSWORD='password' RUST_LOG=info ./fiber-payee/fnn -c ./fiber-payee/config.yml -d ./fiber-payee"
    },
    "devDependencies": {
        "typescript": "^5.5.4",
        "vitest": "^2.1.1"
    },
    "packageManager": "pnpm@9.12.0"
}