NODE_ENV=production
HOST=127.0.0.1
PORT=4000
DATABASE_URL=postgresql://fibermeter:REPLACE_DATABASE_PASSWORD@127.0.0.1:5432/fibermeter?schema=public
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_VALUE
CORS_ORIGINS=https://app.example.com,https://demo.example.com
DEMO_EMAIL=demo@fibermeter.dev
DEMO_PASSWORD=REPLACE_DEMO_LOGIN_PASSWORD

FIBER_PROVIDER=live
FIBER_RPC_URL=http://127.0.0.1:8237
# Optional payer-side RPC for preflight/dry-run checks. Keep FIBER_RPC_URL on
# the payee because it creates and verifies invoices.
FIBER_PREFLIGHT_RPC_URL=http://127.0.0.1:8247
FIBER_CURRENCY=Fibt
FIBER_INVOICE_EXPIRY_SECS=3600
FIBER_DEMO_AUTOPAY=true
FIBER_DEMO_MAX_PAYMENT_CKB=5
CKB_EXPLORER_URL=https://testnet.explorer.nervos.org
