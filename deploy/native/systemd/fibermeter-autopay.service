[Unit]
Description=FiberMeter bounded testnet auto-payer
After=network-online.target fibermeter-api.service fiber-payer.service
Requires=fibermeter-api.service fiber-payer.service

[Service]
Type=simple
User=fibermeter
Group=fibermeter
WorkingDirectory=/var/www/api.fibermeter.toneflix.net
EnvironmentFile=/etc/fibermeter/autopay.env
ExecStart=/usr/bin/node /var/www/api.fibermeter.toneflix.net/scripts/autopay.mjs
Restart=on-failure
RestartSec=5
PrivateTmp=true
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
