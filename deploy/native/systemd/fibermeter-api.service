[Unit]
Description=FiberMeter API
After=network-online.target postgresql.service fiber-payee.service
Wants=network-online.target

[Service]
Type=simple
User=fibermeter
Group=fibermeter
WorkingDirectory=__APP_ROOT__/apps/api
EnvironmentFile=/etc/fibermeter/api.env
ExecStart=/usr/bin/node __APP_ROOT__/apps/api/dist/src/server.js
Restart=on-failure
RestartSec=5
PrivateTmp=true
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
