# Keep the Docker build context small and reproducible.
**/node_modules
**/dist
**/.turbo
**/.vite

# Local Fiber node data + binaries (large; not needed to build the apps)
/fiber
/fiber-payer
/fiber-payee

# Local env + logs + git
**/.env
**/.env.local
**/*.log
.git
.gitignore

# Editor / OS cruft
.DS_Store
.vscode
.idea
