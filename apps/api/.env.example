DATABASE_URL="postgresql://fibermeter:fibermeter@localhost:5432/fibermeter?schema=public"
JWT_SECRET="dev-secret-change-me"
HOST=0.0.0.0
PORT=4000

# Comma-separated browser origins. Leave empty for permissive local development.
CORS_ORIGINS=

# simulated = fiber-sim:// + Simulate Paid  (DEFAULT — zero external deps, works out of the box)
# live      = real Fiber new_invoice + Verify on Fiber  (requires your own funded Fiber node)
FIBER_PROVIDER=simulated

# Fiber node JSON-RPC — ONLY needed when FIBER_PROVIDER=live.
FIBER_RPC_URL=http://127.0.0.1:8227
# Public testnet example:
# FIBER_RPC_URL=http://18.163.221.211:8227

# Invoice currency: Fibt (testnet) or Fibb (mainnet)
FIBER_CURRENCY=Fibt
FIBER_INVOICE_EXPIRY_SECS=3600

# Optional hosted testnet automation. Keep false for normal live operation.
FIBER_DEMO_AUTOPAY=false
FIBER_DEMO_MAX_PAYMENT_CKB=5
